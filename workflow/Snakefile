import gzip

from Bio import SeqIO
import yaml
import pandas as pd
from os.path import basename
import warnings

METADATA_FILE = "fosmids.xlsx"
DEFAULT_ORGANISM = "Escherichia coli"

with warnings.catch_warnings():
    warnings.filterwarnings("ignore", category = UserWarning, module = re.escape("openpyxl.styles.stylesheet"))
    metadata_df = pd.read_excel(METADATA_FILE, dtype = str, engine = "openpyxl")

metadata = metadata_df.where(metadata_df.notnull(), None).set_index('id').to_dict(orient='index')

fosmids = list(metadata.keys())

db_dirs, db_prefixes ,= glob_wildcards("databases/{dir}/{prefix}.ndb")

wildcard_constraints:
    id = '|'.join(fosmids),
    db_dir = '|'.join(db_dirs),
    db_prefix = '|'.join(db_prefixes)

rule all:
    input:
        expand("output/{id}/{id}.gbk", id = fosmids),
        expand("output/{id}/{id}_classifications.tsv", id = fosmids)
        #expand(expand("analysis/tblastn/{{id}}/{db_dir}_{db_prefix}.txt", zip, db_dir = db_dirs, db_prefix = db_prefixes), id = fosmids)

rule dload_gbf2tbl:
    output:
        "analysis/tools/gbf2tbl.pl"
    params:
        url = "https://ftp.ncbi.nlm.nih.gov/toolbox/ncbi_tools/converters/scripts/gbf2tbl.pl"
    shell:
        "wget -qO {output} {params.url}"

rule trim_paired:
    input:
        r1 = lambda w: f"raw/{metadata[w.id]['illumina1']}",
        r2 = lambda w: f"raw/{metadata[w.id]['illumina2']}"
    output:
        r1 = "analysis/trim/{id}_val_1.fq.gz",
        r2 = "analysis/trim/{id}_val_2.fq.gz"
    params:
        dirname = "analysis/trim"
    conda:
        "envs/tools.yaml"
    shell:
        "trim_galore --paired {input} --basename {wildcards.id} --output_dir {params.dirname}"

rule vector_illumina_trim:
    input:
        r1 = "analysis/trim/{id}_val_1.fq.gz",
        r2 = "analysis/trim/{id}_val_2.fq.gz",
        vector = "analysis/vector/middle.fna"
    output:
        r1 = "analysis/vector_trim/{id}_R1.fastq.gz",
        r2 = "analysis/vector_trim/{id}_R2.fastq.gz",
        tmp1 = temp("analysis/vector_trim/{id}_too_short_R1.fastq.gz"),
        tmp2 = temp("analysis/vector_trim/{id}_too_short_R2.fastq.gz")
    params:
        min_len = 50
    log:
        "analysis/vector_trim/{id}.log"
    conda:
        "envs/tools.yaml"
    threads:
        10
    shell:
        "cutadapt -j {threads} -b file:{input.vector} -B file:{input.vector} -m {params.min_len} -o {output.r1} -p {output.r2} --too-short-output {output.tmp1} --too-short-paired-output {output.tmp2} {input.r1} {input.r2} &> {log}"

rule vector_illumina_unpaired:
    input:
        "analysis/vector_trim/{id}_too_short_R1.fastq.gz",
        "analysis/vector_trim/{id}_too_short_R2.fastq.gz"
    output:
        "analysis/vector_trim/{id}_U.fastq.gz"
    params:
        min_len = 50
    conda:
        "envs/tools.yaml"
    shell:
        "seqkit seq -m {params.min_len} -o {output.unpaired} {input}"

def vector_nanopore_find_input(wildcards):
    id = wildcards.id
    i = int(wildcards.i)
    return f"raw/{metadata[id]['nanopore']}" if i == 1 else f"analysis/vector_trim/{id}_{i-1}_trimmed.fastq.gz"

rule vector_nanopore_find:
    input:
        fastq = vector_nanopore_find_input,
        vector = "analysis/vector/middle.fna"
    output:
        "analysis/vector_trim/{id}_{i}.tsv"
    log:
        "analysis/vector_trim/{id}_{i}.log"
    conda:
        "envs/tools.yaml"
    threads:
        10
    shell:
        "cutadapt -j {threads} --rc -b file:{input.vector} --info-file {output} -o /dev/null {input.fastq} &> {log}"

checkpoint vector_nanopore_trim:
    input:
        "analysis/vector_trim/{id}_{i}.tsv"
    output:
        trimmed = "analysis/vector_trim/{id}_{i}_trimmed.fastq.gz",
        passed = "analysis/vector_trim/{id}_{i}_passed.fastq.gz"
    params:
        min_len = 200
    conda:
        "envs/python.yaml"
    script:
        "scripts/vector_nanopore_trim.py"

rule vector_middle:
    input:
        "workflow/metadata/vector.fna"
    output:
        "analysis/vector/middle.fna"
    params:
        flanks = 2000
    conda:
        "envs/tools.yaml"
    shell:
        "seqkit subseq -r {params.flanks}:-{params.flanks} -o {output} {input}"

def flye_input(wildcards):
    files = []
    for i in range(1, 100):
        trim_output = checkpoints.vector_nanopore_trim.get(id = wildcards.id, i = i).output
        with gzip.open(trim_output.trimmed, 'rb') as f:
            if not f.read(1): break
        files.append(trim_output.passed)
    return files

rule flye:
    input:
        flye_input
    output:
        directory("analysis/flye/{id}")
    log:
        "analysis/flye/{id}.log"
    threads:
        10
    conda:
        "envs/flye.yaml"
    shell:
        "flye --nano-raw {input} --out-dir {output} --threads {threads} &> {log}"

rule spades:
    input:
        r1 = "analysis/vector_trim/{id}_R1.fastq.gz",
        r2 = "analysis/vector_trim/{id}_R2.fastq.gz",
        U = "analysis/vector_trim/{id}_U.fastq.gz"
    output:
        directory("analysis/spades/{id}")
    threads:
        10
    conda:
        "envs/spades.yaml"
    shell:
        "spades.py -t {threads} -1 {input.r1} -2 {input.r2} -o {output}"

def choose_assembly(wildcards):
    id = wildcards.id
    fosmid = metadata[id]
    if fosmid['illumina1']:
        return "analysis/spades/{id}/scaffolds.fasta"
    if fosmid['nanopore']:
        return "analysis/flye/{id}/assembly.fasta"
    if fosmid['pre_assembled']:
        return Path("pre_assembled") / fosmid['pre_assembled']
    raise ValueError(f"Unrecognized assembly source: '{assembly}'. Expected 'spades', 'flye' or a file in directory assembly/")

rule trim_vector_from_assembly:
    input:
        contigs = choose_assembly,
        vector = "workflow/metadata/vector.fna"
    output:
        fasta = "analysis/fosmids/{id}.fna",
        info = "analysis/fosmids/{id}.info"
    log:
        "analysis/fosmids/{id}.info.log"
    conda:
        "envs/tools.yaml"
    shell:
        "cutadapt -n 10 --rc -g file:{input.vector} -a file:{input.vector} -o {output.fasta} --info-file {output.info} {input.contigs} &> {log}"

rule make_submol:
    output:
        "analysis/fosmids/{id}_submol.yaml"
    run:
        submol = {
            "topology": 'linear',
            "organism": { "genus_species": metadata[wildcards.id]["ref_organism"] if metadata[wildcards.id]["ref_organism"] else DEFAULT_ORGANISM },
            "locus_tag_prefix": metadata[wildcards.id]["prefix"]
        }
        with open(output[0], "w") as fd:
            yaml.safe_dump(submol, fd, sort_keys=False)

rule make_yaml:
    input:
        fasta  = "analysis/fosmids/{id}.fna",
        submol = "analysis/fosmids/{id}_submol.yaml"
    output:
        "analysis/fosmids/{id}.yaml"
    run:
        sets = {
            "fasta": { "class": "File", "location": basename(input.fasta) },
            "submol": { "class": "File", "location": basename(input.submol) }
        }
        with open(output[0], 'w') as fd:
            yaml.dump(sets, fd)

rule pgap:
    input:
        fasta  = "analysis/fosmids/{id}.fna",
        yaml = "analysis/fosmids/{id}.yaml",
        submol = "analysis/fosmids/{id}_submol.yaml"
    output:
        directory("analysis/pgap/{id}")
    log:
        "analysis/pgap/{id}.log"
    threads:
        8
    shell:
        "pgap.py --debug --ignore-all-errors --report-usage-true --cpu {threads} -o {output} {input.yaml} &> {log}"

