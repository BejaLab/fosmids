def metabuli_output(wildcards, output):
    path = Path(output.report)
    return path.parent, path.name.replace('_report.tsv', '')

rule metabuli:
    input:
        "analysis/pgap/{id}"
    output:
        classifications = "analysis/metabuli/{id}_classifications.tsv",
        report = "analysis/metabuli/{id}_report.tsv"
    log:
        "logs/metabuli/{id}.log"
    params:
        fasta = lambda w, input: f"{input}/annot_cds_from_genomic.fna",
        db_dir = GTDB_PATH,
        out = metabuli_output
    conda:
        "envs/metabuli.yaml"
    threads:
        20
    shell:
        "metabuli classify --lineage 1 --seq-mode 1 --threads {threads} {params.fasta} {params.db_dir} {params.out} &> {log}"

def coverage_read_mode(wildcards):
    id = wildcards.id
    if samples[id]['illumina1']:
        return "illumina"
    if samples[id]['nanopore']:
        return "nanopore"
    return "none"

def coverage_insert_depth_output(wildcards):
    mode = coverage_read_mode(wildcards)
    if mode == "none":
        return None
    return f"analysis/coverage/{wildcards.id}_{mode}.insert.depth.tsv"

def coverage_vector_depth_output(wildcards):
    mode = coverage_read_mode(wildcards)
    if mode == "none":
        return None
    return f"analysis/coverage/{wildcards.id}_{mode}.vector.depth.tsv"

# Helper function to determine the reference file based on the wildcard
def get_reference(wildcards):
    if wildcards.ref_type == "insert":
        return f"analysis/fosmids/{wildcards.id}.fna"
    elif wildcards.ref_type == "vector":
        return vector_complete_for_fosmid(wildcards)

rule align_illumina:
    input:
        ref = get_reference,
        r1 = lambda w: f"raw/{samples[w.id]['illumina1']}",
        r2 = lambda w: f"raw/{samples[w.id]['illumina2']}"
    output:
        "analysis/coverage/{id}_illumina.{ref_type}.bam"
    log:
        "analysis/coverage/{id}_illumina.{ref_type}.log"
    conda:
        "envs/mapping.yaml"
    threads:
        10
    shell:
        "(minimap2 -ax sr -t {threads} {input.ref} {input.r1} {input.r2} | samtools sort -o {output} -) &> {log}"

rule align_nanopore:
    input:
        ref = get_reference,
        fastq = lambda w: f"raw/{samples[w.id]['nanopore']}"
    output:
        "analysis/coverage/{id}_nanopore.{ref_type}.bam"
    log:
        "analysis/coverage/{id}_nanopore.{ref_type}.log"
    conda:
        "envs/mapping.yaml"
    threads:
        10
    shell:
        "(minimap2 -ax map-ont -t {threads} {input.ref} {input.fastq} | samtools sort -o {output} -) &> {log}"

rule calculate_depth:
    input:
        "analysis/coverage/{id}_{tech}.{ref_type}.bam"
    output:
        "analysis/coverage/{id}_{tech}.{ref_type}.depth.tsv"
    conda:
        "envs/mapping.yaml"
    shell:
        "samtools depth -aa {input} > {output}"

rule final_output:
    input:
        pgap = "analysis/pgap/{id}",
        trim = "analysis/fosmids/{id}.info",
        pretrim_fasta = choose_assembly,
        fasta = "analysis/fosmids/{id}.fna",
        vector = vector_complete_for_fosmid,
        metabuli = "analysis/metabuli/{id}_classifications.tsv",
        metabuli_report = "analysis/metabuli/{id}_report.tsv",
        flye_input = lambda w: flye_input(w) if samples[w.id]["nanopore"] else [],
        insert_depth = lambda w: [p for p in [coverage_insert_depth_output(w)] if p is not None],
        vector_depth = lambda w: [p for p in [coverage_vector_depth_output(w)] if p is not None]
    output:
        gbk = "output/{id}/{id}.gbk",
        report = "output/{id}/report.xlsx"
    params:
        prefix = lambda w: samples[w.id]['prefix'],
        read_mode = coverage_read_mode
    conda:
        "envs/python.yaml"
    script:
        "scripts/final_output.py"
