if not config:
    configfile: "config/config.yaml"
SAMPLES_FILE = config.get("samples_file", "config/samples.xlsx")

GTDB_PATH = config["gtdb_path"]
MIN_CONTIG = config["min_contig"]

with warnings.catch_warnings():
    warnings.filterwarnings("ignore", category = UserWarning, module = re.escape("openpyxl.styles.stylesheet"))
    samples_df = pd.read_excel(SAMPLES_FILE, dtype = str, engine = "openpyxl")

samples_df['vector_name'] = samples_df['vector'].apply(lambda x: Path(x).stem)
vectors = samples_df.drop_duplicates(subset=['vector_name']).set_index('vector_name')['vector'].to_dict()
enzymes = samples_df['enzyme'].unique().tolist()
samples = samples_df.where(samples_df.notnull(), None).set_index('id').to_dict(orient='index')

fosmids = list(samples.keys())

# --- PGAP taxonomy validation ---
def get_pgap_taxonomy_path():
    install_dir = Path(os.getenv('PGAP_INPUT_DIR', Path.home() / '.pgap'))
    if not install_dir.exists():
        raise FileNotFoundError("PGAP data directory not found: run `pgap.py --update` first")
    input_dirs = sorted([d for d in install_dir.glob('input-*') if d.is_dir()])
    if not input_dirs:
        raise FileNotFoundError(f"No 'input-*' directories found in {install_dir}: run `pgap.py --update` first")
    latest_input_dir = input_dirs[-1]
    db_path = latest_input_dir / "uniColl_path" / "taxonomy.sqlite3"
    if not db_path.exists():
        raise FileNotFoundError("PGAP's taxonomy database file not found")
    return db_path

def check_organism(organism, tax_conn):
    organism = str(organism).strip()
    if not organism or organism.lower() == "nan":
        raise ValueError("Organism must be non-empty.")
    cur = tax_conn.cursor()
    rows = cur.execute("SELECT rank, org_ref_asn FROM TaxidInfo WHERE scientific_name = ?", (organism,)).fetchall()
    if not rows:
        raise ValueError(f"Organism '{organism}' was not found in PGAP taxonomy.")
    if len(rows) > 1:
        raise ValueError(f"Organism '{organism}' has multiple matches in PGAP taxonomy.")
    rank, org_ref_asn = rows[0]
    if rank != 'species':
        raise ValueError(f"Organism '{organism}' must be a species, got '{rank}' instead.")
    if match := re.search(r'lineage\s+"([^"]+)"', org_ref_asn):
        ancestor = match.group(1).split(';')[0]
        if ancestor not in ("Bacteria", "Archaea"):
            raise ValueError(f"Organism '{organism}' must be a bacterium or an archaeon, it belongs instead to '{ancestor}'")
    else:
        raise ValueError(f"Unexpected format of org_ref_asn: '{org_ref_asn}'.")

tax_db_path = get_pgap_taxonomy_path()

with sqlite3.connect(tax_db_path) as tax_conn:
    for org in samples_df['organism'].unique():
        check_organism(org, tax_conn)
