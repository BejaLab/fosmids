def choose_assembly(wildcards):
    id = wildcards.id
    fosmid = samples[id]
    if fosmid['illumina1']:
        return "analysis/spades/{id}/scaffolds.fasta"
    if fosmid['nanopore']:
        return "analysis/flye/{id}/assembly.fasta"
    if fosmid['pre_assembled']:
        return Path("pre_assembled") / fosmid['pre_assembled']
    raise ValueError(f"Unrecognized assembly source: '{assembly}'. Expected 'spades', 'flye' or a file in directory assembly/")

rule trim_vector_from_assembly:
    input:
        contigs = choose_assembly,
        vector = vector_complete_for_fosmid
    output:
        fasta = "analysis/fosmids/{id}.fna",
        info = "analysis/fosmids/{id}.info"
    params:
        m = MIN_CONTIG
    log:
        "logs/trim_vector_from_assembly/{id}.log"
    conda:
        "envs/tools.yaml"
    shell:
        "cutadapt -n 10 -m {params.m} --rc -g file:{input.vector} -a file:{input.vector} -o {output.fasta} --info-file {output.info} {input.contigs} &> {log}"

rule make_submol:
    output:
        "analysis/fosmids/{id}_submol.yaml"
    params:
        organism = lambda w: samples[w.id]["organism"],
        isolate = lambda w: samples[w.id]["isolate"],
        prefix = lambda w: samples[w.id]["prefix"]
    run:
        submol = { "topology": 'linear', "organism": { "genus_species": params.organism }, "locus_tag_prefix": params.prefix }
        if params.isolate and not pd.isna(params.isolate):
            submol["organism"]["strain"] = params.isolate
        with open(output[0], "w") as fd:
            yaml.safe_dump(submol, fd, sort_keys=False)

rule make_yaml:
    input:
        fasta  = "analysis/fosmids/{id}.fna",
        submol = "analysis/fosmids/{id}_submol.yaml"
    output:
        "analysis/fosmids/{id}.yaml"
    run:
        sets = {
            "fasta": { "class": "File", "location": Path(input.fasta).name },
            "submol": { "class": "File", "location": Path(input.submol).name }
        }
        with open(output[0], 'w') as fd:
            yaml.dump(sets, fd)

rule pgap:
    input:
        fasta  = "analysis/fosmids/{id}.fna",
        yaml = "analysis/fosmids/{id}.yaml",
        submol = "analysis/fosmids/{id}_submol.yaml"
    output:
        directory("analysis/pgap/{id}")
    log:
        "logs/pgap/{id}.log"
    threads:
        8
    shell:
        "pgap.py --debug --ignore-all-errors --report-usage-true --no-self-update --no-internet --cpu {threads} -o {output} {input.yaml} &> {log}"

