rule blastn:
    input:
        "analysis/fosmids/{id}.fna"
    output:
        "analysis/blastn/{id}/{db_dir}_{db_prefixes}.txt"
    params:
        db = "databases/{db_dir}/{db_prefixes}",
        outfmt = "6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore stitle",
        num = 10
    conda:
        "envs/blast.yaml"
    threads:
        10
    shell:
        "blastn -query {input} -db {params.db} -out {output} -outfmt '{params.outfmt}' -num_threads {threads} -max_target_seqs {params.num}"

rule tblastn:
    input:
        "analysis/pgap/{id}"
    output:
        "analysis/tblastn/{id}/{db_dir}_{db_prefixes}.txt"
    params:
        db = "databases/{db_dir}/{db_prefixes}",
        outfmt = "6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore stitle",
        num = 10
    conda:
        "envs/blast.yaml"
    threads:
        10
    shell:
        "tblastn -query {input}/annot.faa -db {params.db} -out {output} -outfmt '{params.outfmt}' -num_threads {threads} -max_target_seqs {params.num}"

def metabuli_output(wildcards, output):
    path = Path(output[0])
    return path.parent, path.name.replace('_classifications.tsv', '')

rule metabuli:
    input:
        pgap = "analysis/pgap/{id}"
    output:
        "output/{id}/{id}_classifications.tsv"
    params:
        fasta = "analysis/pgap/{id}/annot_cds_from_genomic.fna",
        db_dir = "/data/metabuli/gtdb226db",
        out = metabuli_output
    conda:
        "envs/metabuli.yaml"
    threads:
        20
    shell:
        "metabuli classify --lineage 1 --seq-mode 1 --threads {threads} {params.fasta} {params.db_dir} {params.out}"

