rule trim_paired:
    input:
        r1 = lambda w: f"raw/{samples[w.id]['illumina1']}",
        r2 = lambda w: f"raw/{samples[w.id]['illumina2']}"
    output:
        r1 = "analysis/trim/{id}_val_1.fq.gz",
        r2 = "analysis/trim/{id}_val_2.fq.gz"
    log:
        "logs/trim_paired/{id}.log"
    params:
        dirname = "analysis/trim"
    conda:
        "envs/tools.yaml"
    shell:
        "trim_galore --paired {input} --basename {wildcards.id} --output_dir {params.dirname} &> {log}"

def vector_middle_for_fosmid(wildcards):
    vector_name = samples[wildcards.id]['vector_name']
    enzyme = samples[wildcards.id]['enzyme']
    return f"analysis/vectors/{vector_name}_{enzyme}_middle.fna"

def vector_complete_for_fosmid(wildcards):
    vector_name = samples[wildcards.id]['vector_name']
    enzyme = samples[wildcards.id]['enzyme']
    return f"analysis/vectors/{vector_name}_{enzyme}.fna"

rule vector_illumina_trim:
    input:
        r1 = "analysis/trim/{id}_val_1.fq.gz",
        r2 = "analysis/trim/{id}_val_2.fq.gz",
        vector = vector_middle_for_fosmid
    output:
        r1 = "analysis/vector_trim/{id}_R1.fastq.gz",
        r2 = "analysis/vector_trim/{id}_R2.fastq.gz",
        tmp1 = temp("analysis/vector_trim/{id}_too_short_R1.fastq.gz"),
        tmp2 = temp("analysis/vector_trim/{id}_too_short_R2.fastq.gz")
    params:
        min_len = 50
    log:
        "log/vector_trim/{id}.log"
    conda:
        "envs/tools.yaml"
    threads:
        10
    shell:
        "cutadapt -j {threads} -b file:{input.vector} -B file:{input.vector} -m {params.min_len} -o {output.r1} -p {output.r2} --too-short-output {output.tmp1} --too-short-paired-output {output.tmp2} {input.r1} {input.r2} &> {log}"

rule vector_illumina_unpaired:
    input:
        "analysis/vector_trim/{id}_too_short_R1.fastq.gz",
        "analysis/vector_trim/{id}_too_short_R2.fastq.gz"
    output:
        "analysis/vector_trim/{id}_U.fastq.gz"
    params:
        min_len = 50
    conda:
        "envs/tools.yaml"
    shell:
        "seqkit seq -gm {params.min_len} -o {output} {input}"

def vector_nanopore_find_input(wildcards):
    id = wildcards.id
    i = int(wildcards.get('i', 1))
    return f"raw/{samples[id]['nanopore']}" if i == 1 else f"analysis/vector_trim/{id}_{i-1}_trimmed.fastq.gz"

rule vector_nanopore_find:
    input:
        fastq = vector_nanopore_find_input,
        vector = vector_middle_for_fosmid
    output:
        "analysis/vector_trim/{id}_{i}.tsv"
    params:
        min_overlap = 200
    log:
        "logs/vector_trim/{id}_{i}.log"
    conda:
        "envs/tools.yaml"
    threads:
        10
    shell:
        "cutadapt -j {threads} -O {params.min_overlap} --rc -b file:{input.vector} --info-file {output} -o /dev/null {input.fastq} &> {log}"

checkpoint vector_nanopore_trim:
    input:
        "analysis/vector_trim/{id}_{i}.tsv"
    output:
        trimmed = "analysis/vector_trim/{id}_{i}_trimmed.fastq.gz",
        passed = "analysis/vector_trim/{id}_{i}_passed.fastq.gz"
    params:
        min_len = 200
    conda:
        "envs/python.yaml"
    script:
        "scripts/vector_nanopore_trim.py"

rule vector_middle:
    input:
        "analysis/vectors/{vector}_{enzyme}.fna"
    output:
        "analysis/vectors/{vector}_{enzyme}_middle.fna"
    params:
        flanks = 2000
    conda:
        "envs/tools.yaml"
    shell:
        "seqkit subseq -r {params.flanks}:-{params.flanks} -o {output} {input}"

def flye_input(wildcards):
    files = []
    for i in range(1, 100):
        trim_output = checkpoints.vector_nanopore_trim.get(id = wildcards.id, i = i).output
        files.append(trim_output.passed)
        with gzip.open(trim_output.trimmed, 'rb') as f:
            if not f.read(1): break
    return files

rule flye_with_vector:
    input:
        vector_nanopore_find_input
    output:
        out_dir = directory("analysis/flye_with_vector/{id}"),
        out_fasta = "analysis/flye_with_vector/{id}/assembly.fasta"
    log:
        "logs/flye_with_vector/{id}.log"
    threads:
        10
    conda:
        "envs/flye.yaml"
    shell:
        "flye --nano-raw {input} --out-dir {output.out_dir} --threads {threads} &> {log}"

